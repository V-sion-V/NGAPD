{
  "name": "ngapd",
  "version": "0.0.0",
  "private": true,
  "description": "NGAPD monorepo",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 --if-present build",
    "build:packages": "pnpm --filter \"./packages/**\" --workspace-concurrency=1 build",
    "check": "pnpm format:check && pnpm lint && pnpm build && pnpm typecheck && pnpm test",
    "db:migrate": "pnpm --filter @ngapd/database migrate",
    "dev": "pnpm build:packages && concurrently -n api,worker,web -c blue,magenta,green \"pnpm --filter @ngapd/api dev\" \"pnpm --filter @ngapd/worker dev\" \"pnpm --filter @ngapd/web dev\"",
    "dev:api": "pnpm build:packages && pnpm --filter @ngapd/api dev",
    "dev:workspace": "pnpm build:packages && pnpm --filter @ngapd/workspace-cli dev --",
    "dev:web": "pnpm build:packages && pnpm --filter @ngapd/web dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "pnpm -r --workspace-concurrency=1 --if-present test",
    "typecheck": "pnpm -r --workspace-concurrency=1 --if-present typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@ngapd/workspace-cli": "workspace:*",
    "@types/node": "^24.10.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "vitest": "^4.0.15"
  }
}
