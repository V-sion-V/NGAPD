# Local development
NODE_ENV=development
LOG_LEVEL=info
API_HOST=0.0.0.0
API_PORT=3000
WEB_API_BASE_URL=http://localhost:3000

# PostgreSQL
POSTGRES_DB=ngapd
POSTGRES_USER=ngapd
POSTGRES_PASSWORD=replace-before-deployment
DATABASE_URL=postgres://ngapd:replace-before-deployment@localhost:5432/ngapd

# Docker Compose gateway. Production/VPN deployments should use a resolvable host.
NGAPD_SITE_ADDRESS=https://ngapd.local

# Persistent server paths
OBJECT_STORE_PATH=/var/lib/ngapd/objects
BACKUP_PATH=/var/lib/ngapd/backups
